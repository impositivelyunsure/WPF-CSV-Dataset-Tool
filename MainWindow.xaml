<Window x:Class="Malin_SSS_AT3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Malin_SSS_AT3"
        mc:Ignorable="d"
        Title="MainWindow" Height="750" Width="1256">
    <Grid Margin="0,0,0,-6">
        <ListBox Name="lstBoxDisplay" Margin="508,149,508,32">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="IsEnabled" Value="False"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
        <ListBox Name="lstBoxSecondDisplay" Margin="990,149,26,32" SelectionChanged="lstBox_SelectionChanged"/>

        <TextBox Name="txtBoxName" TextChanged="txtBoxName_TextChanged" HorizontalAlignment="Left" Margin="10,133,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox Name="txtBoxClientID" TextChanged="txtBoxClientID_TextChanged" HorizontalAlignment="Left" Margin="10,203,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Label Content="Name" HorizontalAlignment="Left" Margin="10,102,0,0" VerticalAlignment="Top"/>
        <Label Content="Client ID" HorizontalAlignment="Left" Margin="10,177,0,0" VerticalAlignment="Top"/>
    </Grid>
</Window>
